{
  "manifest_version": 2,
  "name": "Site Time Limiter",
  "version": "1.0.0",
  "description": "Limit daily time spent on distracting websites like Twitter, Reddit, and YouTube",
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon.svg",
    "default_title": "Site Time Limiter"
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "web_accessible_resources": [
    "blocked/blocked.html"
  ]
}

# Server
# Local dev: 3000.  Production (behind nginx /curb/): 3006.
PORT=3000
BASE_URL=http://localhost:3000

# JWT (must be at least 32 chars)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-random-secret-here-min-32-chars

# AWS SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
EMAIL_FROM=curb_noreply@lawrencehook.com

# AWS S3 (sync documents live here, keyed by email)
# Objects land at s3://<bucket>/<email>/policies.json
S3_BUCKET=curb-extension
